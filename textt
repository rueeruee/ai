import heapq
N = 4
# heuristic function: count attacking queen pairs
def heuristic(state):
    h = 0
    for i in range(len(state)):
        for j in range(i+1, len(state)):
            if state[i] == state[j] or abs(state[i] - state[j]) == abs(i - j):
                h += 1
    return h
def a_star():
    # priority queue
    pq = []
    heapq.heappush(pq, (0, []))  # (f(n), state)
    while pq:
        f, state = heapq.heappop(pq)
        row = len(state)
        # goal condition
        if row == N and heuristic(state) == 0:
            return state
        if row < N:
            for col in range(N):
                new_state = state + [col]
                g = len(new_state)
                h = heuristic(new_state)
                f = g + h
                heapq.heappush(pq, (f, new_state))
solution = a_star()
print("Solution (column positions):", solution)

