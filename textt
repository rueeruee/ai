def solve_n_queens(n):
    # ---------- BACKTRACKING METHOD ----------
    board1 = [[0]*n for _ in range(n)]
    def is_safe(board, row, col):
        # check column
        for i in range(row):
            if board[i][col] == 1:
                return False

        # check left diagonal
        i, j = row-1, col-1
        while i >= 0 and j >= 0:
            if board[i][j] == 1:
                return False
            i -= 1
            j -= 1
        # check right diagonal
        i, j = row-1, col+1
        while i >= 0 and j < n:
            if board[i][j] == 1:
                return False
            i -= 1
            j += 1
        return True

    def backtracking(row):
        if row == n:
            return True
        for col in range(n):
            if is_safe(board1, row, col):
                board1[row][col] = 1
                if backtracking(row+1):
                    return True
                board1[row][col] = 0  # backtrack
        return False

    # ---------- BRANCH AND BOUND METHOD ----------
    board2 = [[0]*n for _ in range(n)]
    column = [False]*n
    diag1 = [False]*(2*n-1)
    diag2 = [False]*(2*n-1)
    def branch_bound(row):
        if row == n:
            return True
        for col in range(n):
            if not column[col] and not diag1[row+col] and not diag2[row-col+n-1]:
                board2[row][col] = 1
                column[col] = True
                diag1[row+col] = True
                diag2[row-col+n-1] = True

                if branch_bound(row+1):
                    return True
                board2[row][col] = 0
                column[col] = False
                diag1[row+col] = False
                diag2[row-col+n-1] = False
        return False

    # ---------- RUN BOTH ----------
    if backtracking(0):
        print("\nBacktracking Solution:")
        for r in board1:
            print(r)
    else:
        print("No solution using Backtracking")
    if branch_bound(0):
        print("\nBranch and Bound Solution:")
        for r in board2:
            print(r)
    else:
        print("No solution using Branch and Bound")
# ---- MAIN ----
n = int(input("Enter number of queens: "))
solve_n_queens(n)



















